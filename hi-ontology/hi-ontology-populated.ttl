### Minimal tasks added so that executions realize an actual HI task
hi:Task_CollaborativeGameStrategy a hi:Task ;
    rdfs:label "Collaborative game strategy task"@en ;
    hi:requiresCapability hi:Collaborativeness, hi:Communication .

hi:Task_EnvironmentReconstruction a hi:Task ;
    rdfs:label "Environment reconstruction task"@en ;
    hi:requiresCapability hi:Adaptiveness, hi:Communication .

hi:Task_GazePersonalization a hi:Task ;
    rdfs:label "Gaze-aware personalization task"@en ;
    hi:requiresCapability hi:Adaptiveness, hi:Communication .

hi:Task_LifestyleRecommendation a hi:Task ;
    rdfs:label "Lifestyle recommendation task"@en ;
    hi:requiresCapability hi:Adaptiveness, hi:Responsibility .

hi:Task_MoralJudgementSupport a hi:Task ;
    rdfs:label "Moral judgement support task"@en ;
    hi:requiresCapability hi:Transparency, hi:Responsibility .

hi:Task_PolicySimulation a hi:Task ;
    rdfs:label "Policy simulation task"@en ;
    hi:requiresCapability hi:Adaptiveness, hi:Transparency .

hi:Task_TrustCalibration a hi:Task ;
    rdfs:label "Trust calibration task"@en ;
    hi:requiresCapability hi:Adaptiveness, hi:Transparency .

### Task executions mapped from DecisionEvent_*
hi:DecisionEvent_CollaborativeGameStrategy a hi:TaskExecution ;
    rdfs:label "Decision event: collaborative game strategy"@en ;
    hi:realizesTask hi:Task_CollaborativeGameStrategy ;
    hi:performedBy hi:AI_TrustGameTeammate, hi:Human_User ;
    hi:hasInteractionEpisode hi:Interaction_CollaborativeGameStrategy ;
    hi:hasInputData hi:Data_TrustGameLogs, hi:Evidence_GameInteractionLogs ;
    hi:hasOutputData hi:Recommendation_CollaborationStrategy, hi:Justification_TrustFactorModel .

hi:DecisionEvent_EnvironmentReconstruction a hi:TaskExecution ;
    rdfs:label "Decision event: environment reconstruction"@en ;
    hi:realizesTask hi:Task_EnvironmentReconstruction ;
    hi:performedBy hi:AI_PaleoReconstructionAssistant, hi:Human_Researcher ;
    hi:hasInteractionEpisode hi:Interaction_EnvironmentReconstruction ;
    hi:hasInputData hi:Data_ArchaeologyRecords, hi:Evidence_ArchaeologicalRecords ;
    hi:hasOutputData hi:Recommendation_ReconstructionHypothesis, hi:Justification_DataDrivenReconstruction .

hi:DecisionEvent_GazeInteraction1 a hi:TaskExecution ;
    rdfs:label "Decision event: gaze interaction"@en ;
    hi:realizesTask hi:Task_GazePersonalization ;
    hi:performedBy hi:AI_GazeAwareConversationalAgent, hi:Human_User ;
    hi:hasInteractionEpisode hi:Interaction_GazeInteraction1 ;
    hi:hasInputData hi:Data_GazeTrackingStream, hi:Evidence_GazeAttentionData ;
    hi:hasOutputData hi:Recommendation_GazePersonalizedResponse, hi:Justification_GazeBasedPersonalization .

hi:DecisionEvent_LifestyleRecommendation a hi:TaskExecution ;
    rdfs:label "Decision event: lifestyle recommendation"@en ;
    hi:realizesTask hi:Task_LifestyleRecommendation ;
    hi:performedBy hi:AI_SocialHealthCoach, hi:Human_User ;
    hi:hasInteractionEpisode hi:Interaction_LifestyleRecommendation ;
    hi:hasInputData hi:Data_LifestyleLogs, hi:Evidence_LifestyleLogs ;
    hi:hasOutputData hi:Recommendation_LifestyleChange, hi:Justification_BehavioralAnalysis .

hi:DecisionEvent_MoralJudgement a hi:TaskExecution ;
    rdfs:label "Decision event: moral judgement"@en ;
    hi:realizesTask hi:Task_MoralJudgementSupport ;
    hi:performedBy hi:AI_LLM_MoralReasoner, hi:Human_Expert ;
    hi:hasInteractionEpisode hi:Interaction_MoralJudgement ;
    hi:hasInputData hi:Data_MoralDilemmaSet, hi:Evidence_MoralDataset ;
    hi:hasOutputData hi:Recommendation_MoralChoice, hi:Justification_MoralReasoning .

hi:DecisionEvent_PolicySimulation a hi:TaskExecution ;
    rdfs:label "Decision event: policy simulation"@en ;
    hi:realizesTask hi:Task_PolicySimulation ;
    hi:performedBy hi:AI_PolicySimulationAgent, hi:Human_Expert ;
    hi:hasInteractionEpisode hi:Interaction_PolicySimulation ;
    hi:hasInputData hi:Data_PolicySimulationParameters, hi:Evidence_SimulationParameters ;
    hi:hasOutputData hi:Recommendation_PolicyOption, hi:Justification_SimulationResults .

hi:DecisionEvent_TrustCalibration a hi:TaskExecution ;
    rdfs:label "Decision event: trust calibration"@en ;
    hi:realizesTask hi:Task_TrustCalibration ;
    hi:performedBy hi:AI_EEG_TrustCalibrationSystem, hi:Human_User ;
    hi:hasInteractionEpisode hi:Interaction_TrustCalibration ;
    hi:hasInputData hi:Data_EEGSignals, hi:Evidence_EEGSignalsUsed ;
    hi:hasOutputData hi:Recommendation_TrustAdjustment, hi:Justification_EEGSignalAnalysis .

### Interaction episodes added to preserve the original interactingAgent semantics
hi:Interaction_CollaborativeGameStrategy a hi:Interaction ;
    rdfs:label "Interaction episode: collaborative game strategy"@en ;
    hi:hasAgentInvolved hi:AI_TrustGameTeammate, hi:Human_User .

hi:Interaction_EnvironmentReconstruction a hi:Interaction ;
    rdfs:label "Interaction episode: environment reconstruction"@en ;
    hi:hasAgentInvolved hi:AI_PaleoReconstructionAssistant, hi:Human_Researcher .

hi:Interaction_GazeInteraction1 a hi:Interaction ;
    rdfs:label "Interaction episode: gaze interaction"@en ;
    hi:hasAgentInvolved hi:AI_GazeAwareConversationalAgent, hi:Human_User .

hi:Interaction_LifestyleRecommendation a hi:Interaction ;
    rdfs:label "Interaction episode: lifestyle recommendation"@en ;
    hi:hasAgentInvolved hi:AI_SocialHealthCoach, hi:Human_User .

hi:Interaction_MoralJudgement a hi:Interaction ;
    rdfs:label "Interaction episode: moral judgement"@en ;
    hi:hasAgentInvolved hi:AI_LLM_MoralReasoner, hi:Human_Expert .

hi:Interaction_PolicySimulation a hi:Interaction ;
    rdfs:label "Interaction episode: policy simulation"@en ;
    hi:hasAgentInvolved hi:AI_PolicySimulationAgent, hi:Human_Expert .

hi:Interaction_TrustCalibration a hi:Interaction ;
    rdfs:label "Interaction episode: trust calibration"@en ;
    hi:hasAgentInvolved hi:AI_EEG_TrustCalibrationSystem, hi:Human_User .


#################################################################
# Student file 2           
#################################################################

### Capabilities
hi:Creativity a hi:Capability .
hi:SituationalAwareness a hi:Capability ;
    rdfs:comment "Perception of the environment and comprehension of the perceived state."@en .
hi:DynamicMentalizing a hi:Capability ;
    rdfs:comment "Theory-of-mind-like capability used to reason about other agents' intentions and beliefs."@en .

### Methods
hi:CollaborationBased a hi:Method .
hi:ContributionBased a hi:Method .
hi:Multimodal a hi:Method .
hi:CoCreation a hi:Method .
hi:Hybrid a hi:Method .
hi:NeuroSymbolic a hi:Method .
hi:Statistical a hi:Method .
hi:Symbolic a hi:Method .

### Contexts and domains
hi:GeometryFriends a hi:Context ;
    rdfs:comment "A collaborative physics-based puzzle and platform game environment."@en .

hi:CooperativeCuisine a hi:Context ;
    rdfs:comment "A collaborative cooking-game environment inspired by Overcooked!."@en .

hi:EducationDomain a hi:Domain .
hi:SoftwareEngineeringDomain a hi:Domain .
hi:MobilityDomain a hi:Domain .

### Agents and model
hi:AdultUser a hi:HumanAgent, foaf:Person .
hi:TeacherUser a hi:HumanAgent, foaf:Person .
hi:DesignerUser a hi:HumanAgent, foaf:Person .
hi:ChildUser a hi:HumanAgent, foaf:Person .

hi:RobotAgent a hi:ArtificialAgent .
hi:GrammarlyAutocorrect a hi:ArtificialAgent .
hi:TeslaAutosteer a hi:ArtificialAgent .
hi:CodeGenerationController a hi:ArtificialAgent ;
    rdfs:comment "Controller responsible for orchestrating code-generation interactions."@en ;
    hi:hasCapability hi:Communication, hi:Responsibility .

hi:GPT_4o_mini a hi:Model ;
    rdfs:comment "Language model used during task execution."@en ;
    hi:hasMethod hi:Statistical, hi:Hybrid .

### Tasks
hi:CodeGenerationTask a hi:Task ;
    hi:requiresCapability hi:Creativity, hi:Communication .

hi:VoiceToTextTask a hi:Task ;
    hi:requiresCapability hi:Communication .

hi:ExplainabilityTask a hi:Task ;
    hi:requiresCapability hi:Transparency, hi:Communication .

hi:QuestionAnsweringTask a hi:Task ;
    hi:requiresCapability hi:Communication .

hi:RecommendationTask a hi:Task ;
    hi:requiresCapability hi:Collaborativeness, hi:Responsibility .

hi:UserIntentionResolutionTask a hi:Task ;
    hi:requiresCapability hi:DynamicMentalizing, hi:Adaptiveness .

hi:JointActionTask a hi:Task ;
    hi:requiresCapability hi:Collaborativeness, hi:SituationalAwareness .

### Goals
hi:SupportCodeAuthoringGoal a hi:Goal ;
    hi:requiresTask hi:CodeGenerationTask, hi:QuestionAnsweringTask, hi:ExplainabilityTask .

hi:SupportSafeDrivingGoal a hi:Goal ;
    hi:requiresTask hi:RecommendationTask, hi:UserIntentionResolutionTask .

hi:EnableCollaborativeGameplayGoal a hi:Goal ;
    hi:requiresTask hi:JointActionTask .

### Teams
hi:CodeAssistantTeam a hi:HITeam ;
    hi:hasMember hi:AdultUser, hi:CodeGenerationController ;
    hi:hasGoal hi:SupportCodeAuthoringGoal ;
    hi:isInfluencedBy hi:GeometryFriends .

hi:DrivingSupportTeam a hi:HITeam ;
    hi:hasMember hi:AdultUser, hi:TeslaAutosteer ;
    hi:hasGoal hi:SupportSafeDrivingGoal .

hi:CollaborativeGameplayTeam a hi:HITeam ;
    hi:hasMember hi:ChildUser, hi:RobotAgent ;
    hi:hasGoal hi:EnableCollaborativeGameplayGoal ;
    hi:isInfluencedBy hi:GeometryFriends .

### Use cases
hi:CodeAssistantUseCase a hi:UseCase ;
    hi:hasDomain hi:SoftwareEngineeringDomain ;
    hi:hasHITeam hi:CodeAssistantTeam .

hi:DrivingSupportUseCase a hi:UseCase ;
    hi:hasDomain hi:MobilityDomain ;
    hi:hasHITeam hi:DrivingSupportTeam .

hi:CollaborativeGameplayUseCase a hi:UseCase ;
    hi:hasDomain hi:EducationDomain ;
    hi:hasHITeam hi:CollaborativeGameplayTeam .

### Agent capabilities and contexts
hi:AdultUser hi:hasCapability hi:Communication, hi:Responsibility ;
    hi:operatesInContext hi:CooperativeCuisine .

hi:ChildUser hi:hasCapability hi:Collaborativeness ;
    hi:operatesInContext hi:GeometryFriends .

hi:TeacherUser hi:hasCapability hi:Communication, hi:Transparency ;
    hi:operatesInContext hi:CooperativeCuisine .

hi:DesignerUser hi:hasCapability hi:Creativity, hi:Communication .

hi:RobotAgent hi:hasCapability hi:SituationalAwareness, hi:Collaborativeness .
hi:GrammarlyAutocorrect hi:hasCapability hi:Communication, hi:Transparency .
hi:TeslaAutosteer hi:hasCapability hi:Adaptiveness, hi:SituationalAwareness .

### Task executions
hi:CodeGenerationExecution_01 a hi:TaskExecution ;
    hi:realizesTask hi:CodeGenerationTask ;
    hi:towardsGoal hi:SupportCodeAuthoringGoal ;
    hi:performedBy hi:CodeGenerationController ;
    hi:usesModel hi:GPT_4o_mini ;
    hi:hasInputData hi:PromptSpecificationData ;
    hi:hasOutputData hi:GeneratedCodeData ;
    hi:hasInteractionEpisode hi:CodeGenerationInteraction_01 .

hi:DrivingRecommendationExecution_01 a hi:TaskExecution ;
    hi:realizesTask hi:RecommendationTask ;
    hi:towardsGoal hi:SupportSafeDrivingGoal ;
    hi:performedBy hi:TeslaAutosteer ;
    hi:hasInputData hi:DrivingSensorData ;
    hi:hasOutputData hi:DrivingRecommendationData ;
    hi:hasInteractionEpisode hi:DrivingSupportInteraction_01 .

hi:GameplayCoordinationExecution_01 a hi:TaskExecution ;
    hi:realizesTask hi:JointActionTask ;
    hi:towardsGoal hi:EnableCollaborativeGameplayGoal ;
    hi:performedBy hi:RobotAgent ;
    hi:hasInputData hi:GameStateData ;
    hi:hasOutputData hi:GameplayCoordinationData ;
    hi:hasInteractionEpisode hi:GameplayInteraction_01 .

### Interactions
hi:CodeGenerationInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:AdultUser, hi:CodeGenerationController ;
    rdfs:comment "Human-AI interaction around code generation, explanation, and question answering."@en .

hi:DrivingSupportInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:AdultUser, hi:TeslaAutosteer ;
    rdfs:comment "Human-AI interaction around driving recommendations and intention-sensitive support."@en .

hi:GameplayInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:ChildUser, hi:RobotAgent ;
    rdfs:comment "Collaborative interaction in a game-like environment requiring coordinated joint action."@en .

### Data
hi:PromptSpecificationData a hi:Data .
hi:GeneratedCodeData a hi:Data .
hi:DrivingSensorData a hi:Data .
hi:DrivingRecommendationData a hi:Data .
hi:GameStateData a hi:Data .
hi:GameplayCoordinationData a hi:Data .

