hi:LongTermDialogueExecution_01 a hi:TaskExecution ;
    hi:realizesTask hi:LongTermDialogueTask ;
    hi:towardsGoal hi:SustainLongTermDialogueGoal ;
    hi:performedBy hi:Chatbot, hi:Human_User ;
    hi:usesModel hi:GraphMemoMemorySystem ;
    hi:hasInputData hi:LongMemo5Dataset ;
    hi:hasOutputData hi:DialogueResponseData ;
    hi:hasInteractionEpisode hi:MemoryAugmentedDialogueInteraction_01 .

hi:PersonalizedLearningSupportExecution_01 a hi:TaskExecution ;
    hi:realizesTask hi:PersonalizedLearningSupportTask ;
    hi:towardsGoal hi:SupportPersonalizedLearningGoal ;
    hi:performedBy hi:AssistiveRobot, hi:TeacherUser, hi:Therapist ;
    hi:hasInputData hi:LearnerProfileData ;
    hi:hasOutputData hi:LearningSupportRecommendationData ;
    hi:hasInteractionEpisode hi:CollaborativeLearningPlanInteraction_01,
        hi:ProgressReportingInteraction_01,
        hi:PositiveReinforcementInteraction_01 .

### Interactions
hi:ClinicalAdviceTakingInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:Clinician, hi:ClinicalAIDecisionSupportTool ;
    rdfs:comment "Clinical advice-taking interaction under diagnostic uncertainty."@en .

hi:NeurosymbolicRepairInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:LLM_Agent, hi:Human_Expert ;
    rdfs:comment "Interaction for reviewing and repairing candidate ontology content."@en .

hi:KnowledgeAcquisitionInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:Human_Expert, hi:FormalizationAssistantAgent ;
    rdfs:comment "Interaction for eliciting and formalizing domain knowledge."@en .

hi:MemoryAugmentedDialogueInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:Chatbot, hi:Human_User ;
    rdfs:comment "Dialogue interaction supported by long-term memory retrieval."@en .

hi:CollaborativeLearningPlanInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:TeacherUser, hi:Therapist, hi:AssistiveRobot ;
    rdfs:comment "Collaborative planning interaction for personalized learning support."@en .

hi:ProgressReportingInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:TeacherUser, hi:Therapist, hi:AssistiveRobot ;
    rdfs:comment "Interaction for communicating and reviewing learner progress."@en .

hi:PositiveReinforcementInteraction_01 a hi:Interaction ;
    hi:hasAgentInvolved hi:AssistiveRobot, hi:Alex ;
    rdfs:comment "Interaction where the robot reinforces learner engagement and progress."@en .

