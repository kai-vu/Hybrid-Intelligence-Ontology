### Domains
hi:SecurityDomain a hi:Domain ;
    rdfs:label "Security"@en .

hi:CulturalHeritageDomain a hi:Domain ;
    rdfs:label "Cultural heritage"@en .

### Contexts
hi:AdaptiveCybersecurityContext a hi:Context ;
    rdfs:label "Adaptive cybersecurity operations context"@en .

hi:ProteinDiscoveryResearchContext a hi:Context ;
    rdfs:label "Protein discovery research context"@en .

hi:RobotAssistedLearningContext a hi:Context ;
    rdfs:label "Robot-assisted learning support context"@en .

hi:ArchivalCurationContext a hi:Context ;
    rdfs:label "Archival curation context"@en .

### Agents
hi:AISecuritySystem a hi:ArtificialAgent ;
    rdfs:label "AI security system"@en ;
    hi:operatesInContext hi:AdaptiveCybersecurityContext ;
    hi:hasCapability hi:PatternRecognitionForThreatDetection,
        hi:ContinuousLearning,
        hi:RapidExplanationGeneration ;
    hi:performsExecution hi:BlockSuspiciousTrafficExecution .

hi:CybersecurityExpert a hi:HumanAgent, foaf:Person ;
    rdfs:label "Cybersecurity expert"@en ;
    hi:operatesInContext hi:AdaptiveCybersecurityContext ;
    hi:hasCapability hi:SecurityDecisionMaking,
        hi:CybersecurityContextAssessment,
        hi:Communication ;
    hi:performsExecution hi:CrossCheckThreatPredictionExecution,
        hi:RestoreAccessExecution .

hi:AlphaFoldSystem a hi:ArtificialAgent ;
    rdfs:label "AlphaFold system"@en ;
    hi:operatesInContext hi:ProteinDiscoveryResearchContext ;
    hi:hasCapability hi:ProteinStructurePrediction,
        hi:ThreeDimensionalModelGeneration,
        hi:ScientificDataProcessing ;
    hi:performsExecution hi:ProteinAnalysisExecution .

hi:DrEmilyChen a hi:HumanAgent, foaf:Person ;
    rdfs:label "Dr Emily Chen"@en ;
    hi:operatesInContext hi:ProteinDiscoveryResearchContext ;
    hi:hasCapability hi:ClinicalJudgment,
        hi:LiteratureReview,
        hi:ResearchCoordination ;
    hi:performsExecution hi:LiteratureCrossReferencingExecution .

hi:AnnaTherapist a hi:HumanAgent, foaf:Person ;
    rdfs:label "Anna"@en ;
    hi:operatesInContext hi:RobotAssistedLearningContext ;
    hi:hasCapability hi:TherapeuticExpertise,
        hi:BehavioristApproach ;
    hi:performsExecution hi:ChildAssessmentExecution .

hi:LeahTeacher a hi:HumanAgent, foaf:Person ;
    rdfs:label "Leah"@en ;
    hi:operatesInContext hi:RobotAssistedLearningContext ;
    hi:hasCapability hi:PedagogicalSkills,
        hi:TechnologyEnthusiasm ;
    hi:performsExecution hi:EducationalPlanningExecution .

hi:NaoRobot a hi:ArtificialAgent ;
    rdfs:label "NAO robot"@en ;
    hi:operatesInContext hi:RobotAssistedLearningContext ;
    hi:hasCapability hi:ReactiveResponse,
        hi:WizardOfOzInteraction ;
    hi:performsExecution hi:GuidedRobotInteractionExecution .

hi:ArchivalFootageAISystem a hi:ArtificialAgent ;
    rdfs:label "Archival footage AI system"@en ;
    hi:operatesInContext hi:ArchivalCurationContext ;
    hi:hasCapability hi:MultimodalUnderstanding,
        hi:ReinforcementLearningSupport ;
    hi:performsExecution hi:ArchiveVideoSegmentationExecution .

hi:CulturalHeritageSteward a hi:HumanAgent, foaf:Person ;
    rdfs:label "Cultural heritage steward"@en ;
    hi:operatesInContext hi:ArchivalCurationContext ;
    hi:hasCapability hi:CulturalStewardship,
        hi:Negotiation ;
    hi:performsExecution hi:ConsentAndGovernanceNegotiationExecution .

### Capabilities
hi:PatternRecognitionForThreatDetection a hi:Capability ;
    rdfs:label "Pattern recognition for threat detection"@en ;
    hi:allowsTask hi:BlockSuspiciousTrafficTask .

hi:ContinuousLearning a hi:Capability ;
    rdfs:label "Continuous learning"@en ;
    hi:allowsTask hi:CrossCheckThreatPredictionTask .

hi:RapidExplanationGeneration a hi:Capability ;
    rdfs:label "Rapid explanation generation"@en ;
    hi:allowsTask hi:RestoreAccessTask .

hi:SecurityDecisionMaking a hi:Capability ;
    rdfs:label "Security decision making"@en ;
    hi:allowsTask hi:CrossCheckThreatPredictionTask,
        hi:RestoreAccessTask .

hi:CybersecurityContextAssessment a hi:Capability ;
    rdfs:label "Cybersecurity context assessment"@en ;
    hi:allowsTask hi:BlockSuspiciousTrafficTask,
        hi:CrossCheckThreatPredictionTask .

hi:ProteinStructurePrediction a hi:Capability ;
    rdfs:label "Protein structure prediction"@en ;
    hi:allowsTask hi:ProteinAnalysisTask .

hi:ThreeDimensionalModelGeneration a hi:Capability ;
    rdfs:label "3D model generation"@en ;
    hi:allowsTask hi:ProteinModelGenerationTask .

hi:ScientificDataProcessing a hi:Capability ;
    rdfs:label "Scientific data processing"@en ;
    hi:allowsTask hi:ProteinAnalysisTask .

hi:ClinicalJudgment a hi:Capability ;
    rdfs:label "Clinical judgment"@en ;
    hi:allowsTask hi:ProteinAnalysisTask,
        hi:LiteratureCrossReferencingTask .

hi:LiteratureReview a hi:Capability ;
    rdfs:label "Literature review"@en ;
    hi:allowsTask hi:LiteratureCrossReferencingTask .

hi:ResearchCoordination a hi:Capability ;
    rdfs:label "Research coordination"@en ;
    hi:allowsTask hi:ResearchOptimizationTask .

hi:TherapeuticExpertise a hi:Capability ;
    rdfs:label "Therapeutic expertise"@en ;
    hi:allowsTask hi:ChildAssessmentTask .

hi:BehavioristApproach a hi:Capability ;
    rdfs:label "Behaviorist approach"@en ;
    hi:allowsTask hi:ChildAssessmentTask .

hi:PedagogicalSkills a hi:Capability ;
    rdfs:label "Pedagogical skills"@en ;
    hi:allowsTask hi:EducationalPlanningTask .

hi:TechnologyEnthusiasm a hi:Capability ;
    rdfs:label "Technology enthusiasm"@en ;
    hi:allowsTask hi:EducationalPlanningTask,
        hi:GuidedRobotInteractionTask .

hi:ReactiveResponse a hi:Capability ;
    rdfs:label "Reactive response"@en ;
    hi:allowsTask hi:GuidedRobotInteractionTask .

hi:WizardOfOzInteraction a hi:Capability ;
    rdfs:label "Wizard-of-Oz interaction"@en ;
