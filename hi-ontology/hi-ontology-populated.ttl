    rdfs:label "Human-AI decision reliance context"@en .

hi:LongTermDialogueContext a hi:Context ;
    rdfs:label "Long-term dialogue context"@en .

hi:InteractiveMLInspectionContext a hi:Context ;
    rdfs:label "Interactive machine learning inspection context"@en .

#################################################################
# New agents
#################################################################

hi:NeurologistAgent a hi:HumanAgent ;
    rdfs:label "Neurologist"@en ;
    hi:hasCapability hi:ClinicalDecisionSupportCapability, hi:ExplainabilityCapability ;
    hi:operatesInContext hi:ClinicalNeurodiagnosticContext .

hi:ClinicianAgent a hi:HumanAgent ;
    rdfs:label "Clinician"@en ;
    hi:hasCapability hi:TrustAssessmentCapability ;
    hi:operatesInContext hi:HumanAIDecisionRelianceContext .

hi:ChatbotUserAgent a hi:HumanAgent ;
    rdfs:label "Chatbot user"@en ;
    hi:operatesInContext hi:LongTermDialogueContext .

hi:MLPractitionerAgent a hi:HumanAgent ;
    rdfs:label "Machine learning practitioner"@en ;
    hi:hasCapability hi:InteractiveModelInspectionCapability ;
    hi:operatesInContext hi:InteractiveMLInspectionContext .

hi:BrainAgeSupportSystem a hi:ArtificialAgent ;
    rdfs:label "Brain age prediction support system"@en ;
    hi:hasCapability hi:ClinicalDecisionSupportCapability, hi:ExplainabilityCapability ;
    hi:operatesInContext hi:ClinicalNeurodiagnosticContext .

hi:TrustAssessmentSystem a hi:ArtificialAgent ;
    rdfs:label "Trust calibration assessment system"@en ;
    hi:hasCapability hi:TrustAssessmentCapability ;
    hi:operatesInContext hi:HumanAIDecisionRelianceContext .

hi:GraphMemoAgent a hi:ArtificialAgent ;
    rdfs:label "GraphMemo chatbot memory system"@en ;
    hi:hasCapability hi:LongTermMemoryCapability ;
    hi:operatesInContext hi:LongTermDialogueContext .

hi:HILLFrameworkAgent a hi:ArtificialAgent ;
    rdfs:label "HILL interactive inspection framework"@en ;
    hi:hasCapability hi:InteractiveModelInspectionCapability ;
    hi:operatesInContext hi:InteractiveMLInspectionContext .

#################################################################
# New tasks
#################################################################

hi:BrainAgeAssessmentTask a hi:Task ;
    rdfs:label "Brain age assessment"@en ;
    hi:requiresCapability hi:ClinicalDecisionSupportCapability .

hi:ExplainBrainAgePredictionTask a hi:Task ;
    rdfs:label "Explain brain age prediction"@en ;
    hi:requiresCapability hi:ExplainabilityCapability .

hi:TrustCalibrationAssessmentTask a hi:Task ;
    rdfs:label "Assess trust calibration"@en ;
    hi:requiresCapability hi:TrustAssessmentCapability .

hi:LongTermMemoryRetrievalTask a hi:Task ;
    rdfs:label "Retrieve long-term dialogue memory"@en ;
    hi:requiresCapability hi:LongTermMemoryCapability .

hi:LatentSpaceInspectionTask a hi:Task ;
    rdfs:label "Inspect latent model representations"@en ;
    hi:requiresCapability hi:InteractiveModelInspectionCapability .

#################################################################
# New goals
#################################################################

hi:SupportBrainAgeInterpretationGoal a hi:Goal ;
    rdfs:label "Support interpretable brain age assessment"@en ;
    hi:requiresTask hi:BrainAgeAssessmentTask , hi:ExplainBrainAgePredictionTask .

hi:DetectTrustCalibrationGoal a hi:Goal ;
    rdfs:label "Detect trust calibration in human-AI interaction"@en ;
    hi:requiresTask hi:TrustCalibrationAssessmentTask .

hi:MaintainLongTermConversationGoal a hi:Goal ;
    rdfs:label "Maintain coherent long-term conversation"@en ;
    hi:requiresTask hi:LongTermMemoryRetrievalTask .

hi:ImproveHumanModelInspectionGoal a hi:Goal ;
    rdfs:label "Improve human inspection of learned model representations"@en ;
    hi:requiresTask hi:LatentSpaceInspectionTask .

#################################################################
# Use cases and teams
#################################################################

hi:BrainAgePredictionUseCase a hi:UseCase ;
    rdfs:label "Explainable brain age prediction"@en ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:BrainAgePredictionTeam .

hi:BrainAgePredictionTeam a hi:HITeam ;
    rdfs:label "Brain age prediction HI team"@en ;
    hi:hasMember hi:NeurologistAgent , hi:BrainAgeSupportSystem ;
    hi:hasGoal hi:SupportBrainAgeInterpretationGoal ;
    hi:isInfluencedBy hi:ClinicalNeurodiagnosticContext .

hi:TrustCalibrationUseCase a hi:UseCase ;
    rdfs:label "EEG-based trust calibration assessment"@en ;
    hi:hasDomain hi:HealthcareDomain ;
    hi:hasHITeam hi:TrustCalibrationTeam .

hi:TrustCalibrationTeam a hi:HITeam ;
    rdfs:label "Trust calibration HI team"@en ;
    hi:hasMember hi:ClinicianAgent , hi:TrustAssessmentSystem ;
    hi:hasGoal hi:DetectTrustCalibrationGoal ;
    hi:isInfluencedBy hi:HumanAIDecisionRelianceContext .

hi:LongTermChatbotMemoryUseCase a hi:UseCase ;
    rdfs:label "Graph-based long-term chatbot memory"@en ;
    hi:hasDomain hi:ConversationalAIDomain ;
    hi:hasHITeam hi:LongTermChatbotMemoryTeam .

hi:LongTermChatbotMemoryTeam a hi:HITeam ;
    rdfs:label "Long-term chatbot memory HI team"@en ;
    hi:hasMember hi:ChatbotUserAgent , hi:GraphMemoAgent ;
    hi:hasGoal hi:MaintainLongTermConversationGoal ;
    hi:isInfluencedBy hi:LongTermDialogueContext .

hi:HILLInspectionUseCase a hi:UseCase ;
    rdfs:label "Human in the Latent Loop model inspection"@en ;
    hi:hasDomain hi:ArtificialIntelligenceResearchDomain ;
    hi:hasHITeam hi:HILLInspectionTeam .

hi:HILLInspectionTeam a hi:HITeam ;
    rdfs:label "HILL inspection HI team"@en ;
    hi:hasMember hi:MLPractitionerAgent , hi:HILLFrameworkAgent ;
    hi:hasGoal hi:ImproveHumanModelInspectionGoal ;
    hi:isInfluencedBy hi:InteractiveMLInspectionContext .

#################################################################
# Task executions and interactions
#################################################################

hi:BrainAgeAssessmentExecution a hi:TaskExecution ;
    rdfs:label "Brain age assessment execution"@en ;
    hi:realizesTask hi:BrainAgeAssessmentTask ;
    hi:towardsGoal hi:SupportBrainAgeInterpretationGoal ;
    hi:performedBy hi:BrainAgeSupportSystem ;
    hi:usesModel hi:BrainAgePredictionModel_Instance ;
    hi:hasInputData hi:BrainImagingData ;
    hi:hasOutputData hi:BrainAgePredictionOutput ;
    hi:hasInteractionEpisode hi:BrainAgeInterpretationInteraction ;
    hi:evaluatedBy hi:BrainAgeEvaluation .

hi:BrainAgeExplanationExecution a hi:TaskExecution ;
    rdfs:label "Brain age explanation execution"@en ;
    hi:realizesTask hi:ExplainBrainAgePredictionTask ;
    hi:towardsGoal hi:SupportBrainAgeInterpretationGoal ;
    hi:performedBy hi:BrainAgeSupportSystem ;
    hi:usesModel hi:BrainAgePredictionModel_Instance ;
    hi:hasInputData hi:BrainAgePredictionOutput ;
    hi:hasOutputData hi:BrainAgeExplanationData ;
    hi:hasInteractionEpisode hi:BrainAgeInterpretationInteraction ;
    hi:evaluatedBy hi:BrainAgeEvaluation .

hi:BrainAgeExplanationData a hi:Data ;
    rdfs:label "Brain age explanation data"@en .

hi:BrainAgeInterpretationInteraction a hi:Interaction ;
    rdfs:label "Brain age interpretation interaction"@en ;
    hi:hasAgentInvolved hi:NeurologistAgent , hi:BrainAgeSupportSystem .

hi:TrustCalibrationExecution a hi:TaskExecution ;
    rdfs:label "Trust calibration assessment execution"@en ;
    hi:realizesTask hi:TrustCalibrationAssessmentTask ;
    hi:towardsGoal hi:DetectTrustCalibrationGoal ;
    hi:performedBy hi:TrustAssessmentSystem ;
    hi:usesModel hi:TrustAssessmentModel_Instance ;
    hi:hasInputData hi:EEGTrustSignalData ;
    hi:hasOutputData hi:TrustCalibrationAssessmentData ;
    hi:hasInteractionEpisode hi:TrustCalibrationInteraction ;
    hi:evaluatedBy hi:TrustCalibrationEvaluation .

hi:TrustCalibrationInteraction a hi:Interaction ;
    rdfs:label "Trust calibration review interaction"@en ;
    hi:hasAgentInvolved hi:ClinicianAgent , hi:TrustAssessmentSystem .

hi:LongTermMemoryRetrievalExecution a hi:TaskExecution ;
    rdfs:label "Long-term memory retrieval execution"@en ;
    hi:realizesTask hi:LongTermMemoryRetrievalTask ;
    hi:towardsGoal hi:MaintainLongTermConversationGoal ;
    hi:performedBy hi:GraphMemoAgent ;
    hi:usesModel hi:GraphMemoModel_Instance ;
    hi:hasInputData hi:LongMemoDialogueData ;
    hi:hasOutputData hi:RetrievedMemoryData ;
    hi:hasInteractionEpisode hi:LongTermConversationInteraction ;
    hi:evaluatedBy hi:LongTermMemoryEvaluation .

hi:LongTermConversationInteraction a hi:Interaction ;
    rdfs:label "Long-term conversation interaction"@en ;
    hi:hasAgentInvolved hi:ChatbotUserAgent , hi:GraphMemoAgent .

hi:HILLInspectionExecution a hi:TaskExecution ;
    rdfs:label "Latent-space inspection execution"@en ;
    hi:realizesTask hi:LatentSpaceInspectionTask ;
    hi:towardsGoal hi:ImproveHumanModelInspectionGoal ;
    hi:performedBy hi:HILLFrameworkAgent ;
    hi:usesModel hi:HILLInspectionModel_Instance ;
    hi:hasInputData hi:CIFAR10ImageData , hi:PAMAP2SensorData ;
    hi:hasOutputData hi:LatentSpaceInspectionData ;
    hi:hasInteractionEpisode hi:HILLInspectionInteraction ;
    hi:evaluatedBy hi:HILLEvaluation .

hi:HILLInspectionInteraction a hi:Interaction ;
    rdfs:label "HILL inspection interaction"@en ;
    hi:hasAgentInvolved hi:MLPractitionerAgent , hi:HILLFrameworkAgent .

#################################################################
# Agent-to-execution links
#################################################################

hi:BrainAgeSupportSystem hi:performsExecution hi:BrainAgeAssessmentExecution , hi:BrainAgeExplanationExecution .
hi:TrustAssessmentSystem hi:performsExecution hi:TrustCalibrationExecution .
hi:GraphMemoAgent hi:performsExecution hi:LongTermMemoryRetrievalExecution .
hi:HILLFrameworkAgent hi:performsExecution hi:HILLInspectionExecution .

#################################################################
# Evaluations and experiments
#################################################################

hi:BrainAgeEvaluation a hi:Evaluation ;
    rdfs:label "Brain age prediction evaluation"@en ;
    hi:hasExperiment hi:BrainAgeExperiment ;
    hi:hasMetricConcept hi:InterpretabilityMetric , hi:UsabilityMetric .

hi:BrainAgeExperiment a hi:Experiment ;
    rdfs:label "Brain age prediction experiment"@en ;
    hi:hasMetricTested hi:InterpretabilityMetric , hi:UsabilityMetric ;
    hi:hasNullHypothesis "Explainable support does not improve neurologists' ability to interpret brain age predictions."@en ;
    hi:hasAlternativeHypothesis "Explainable support improves neurologists' interpretation of brain age predictions."@en .

hi:TrustCalibrationEvaluation a hi:Evaluation ;
    rdfs:label "Trust calibration evaluation"@en ;
    hi:hasExperiment hi:TrustCalibrationExperiment ;
    hi:hasMetricConcept hi:TrustCalibrationMetric .

hi:TrustCalibrationExperiment a hi:Experiment ;
    rdfs:label "Trust calibration detection experiment"@en ;
    hi:hasMetricTested hi:TrustCalibrationMetric ;
    hi:hasNullHypothesis "EEG-based assessment does not distinguish calibrated, over-trusting, and under-trusting human-AI interaction states."@en ;
    hi:hasAlternativeHypothesis "EEG-based assessment distinguishes calibrated, over-trusting, and under-trusting human-AI interaction states."@en .

hi:LongTermMemoryEvaluation a hi:Evaluation ;
    rdfs:label "Long-term chatbot memory evaluation"@en ;
    hi:hasExperiment hi:LongTermMemoryExperiment ;
    hi:hasMetricConcept hi:MemoryRetentionMetric .

hi:LongTermMemoryExperiment a hi:Experiment ;
    rdfs:label "Long-term memory retrieval experiment"@en ;
    hi:hasMetricTested hi:MemoryRetentionMetric ;
    hi:hasNullHypothesis "Graph-based memory does not improve long-term dialogue continuity."@en ;
    hi:hasAlternativeHypothesis "Graph-based memory improves long-term dialogue continuity."@en .

hi:HILLEvaluation a hi:Evaluation ;
    rdfs:label "HILL inspection evaluation"@en ;
    hi:hasExperiment hi:HILLExperiment ;
    hi:hasMetricConcept hi:ModelAccuracyMetric , hi:UsabilityMetric .

hi:HILLExperiment a hi:Experiment ;
    rdfs:label "HILL model inspection experiment"@en ;
    hi:hasMetricTested hi:ModelAccuracyMetric , hi:UsabilityMetric ;
    hi:hasNullHypothesis "Interactive latent-space inspection does not improve human understanding or effective inspection of model behaviour."@en ;
    hi:hasAlternativeHypothesis "Interactive latent-space inspection improves human understanding and effective inspection of model behaviour."@en .


##################################################################
# Student file 6
##################################################################

#################################################################
# Domains
#################################################################

hi:VirtualRealityDomain a hi:Domain ;
    rdfs:label "Virtual reality"@en .

hi:GovernanceDomain a hi:Domain ;
    rdfs:label "Governance and public policy"@en .


#################################################################
# Use Case 1 — VR Conversational Interaction
#################################################################

hi:VRConversationalInteractionUseCase a hi:UseCase ;
    rdfs:label "Gaze-aware conversational interaction in VR"@en ;
    hi:hasDomain hi:VirtualRealityDomain ;
    hi:hasHITeam hi:VRDialogueTeam .

hi:VRDialogueTeam a hi:HITeam ;
    rdfs:label "Human–AI VR dialogue team"@en ;
    hi:hasMember hi:HumanParticipant ;
    hi:hasMember hi:VRConversationalAgent ;
    hi:hasGoal hi:VRDialogueGoal .

hi:VRDialogueGoal a hi:Goal ;
    rdfs:label "Maintain natural conversational interaction in VR"@en ;
    hi:requiresTask hi:GazeAwareDialogueTask .

hi:GazeAwareDialogueTask a hi:Task ;
    rdfs:label "Perform gaze-aware dialogue management"@en ;
    hi:requiresCapability hi:Communication ;
    hi:requiresCapability hi:Adaptiveness .

hi:GazeAwareDialogueExecution a hi:TaskExecution ;
    rdfs:label "Execution of gaze-aware VR dialogue"@en ;
    hi:realizesTask hi:GazeAwareDialogueTask ;
    hi:towardsGoal hi:VRDialogueGoal ;
    hi:hasInteractionEpisode hi:VRDialogueInteraction .

hi:HumanParticipant a hi:HumanAgent ;
    rdfs:label "VR user"@en ;
    hi:performsExecution hi:GazeAwareDialogueExecution .

hi:VRConversationalAgent a hi:ArtificialAgent ;
    rdfs:label "Conversational VR agent"@en ;
    hi:performsExecution hi:GazeAwareDialogueExecution .

hi:VRDialogueInteraction a hi:Interaction ;
    rdfs:label "Dialogue interaction in VR environment"@en ;
    hi:hasAgentInvolved hi:HumanParticipant ;
    hi:hasAgentInvolved hi:VRConversationalAgent .


#################################################################
# Use Case 2 — Public Policy Simulation
#################################################################

hi:PublicPolicySimulationUseCase a hi:UseCase ;
    rdfs:label "Participatory public policy simulation"@en ;
    hi:hasDomain hi:GovernanceDomain ;
    hi:hasHITeam hi:PolicySimulationTeam .

hi:PolicySimulationTeam a hi:HITeam ;
    rdfs:label "Human–AI policy simulation team"@en ;
    hi:hasMember hi:PolicyAnalyst ;
    hi:hasMember hi:PolicySimulationAgent ;
    hi:hasGoal hi:PolicySimulationGoal .

hi:PolicySimulationGoal a hi:Goal ;
    rdfs:label "Evaluate potential policy outcomes through simulation"@en ;
    hi:requiresTask hi:ParticipatoryPolicySimulationTask .

hi:ParticipatoryPolicySimulationTask a hi:Task ;
    rdfs:label "Simulate policy scenarios interactively"@en ;
    hi:requiresCapability hi:Communication ;
    hi:requiresCapability hi:Transparency .

hi:PolicySimulationExecution a hi:TaskExecution ;
    rdfs:label "Execution of participatory policy simulation"@en ;
    hi:realizesTask hi:ParticipatoryPolicySimulationTask ;
    hi:towardsGoal hi:PolicySimulationGoal ;
    hi:hasInteractionEpisode hi:PolicySimulationInteraction .

hi:PolicyAnalyst a hi:HumanAgent ;
    rdfs:label "Policy analyst"@en ;
    hi:performsExecution hi:PolicySimulationExecution .

hi:PolicySimulationAgent a hi:ArtificialAgent ;
    rdfs:label "Policy simulation agent"@en ;
    hi:performsExecution hi:PolicySimulationExecution .

hi:PolicySimulationInteraction a hi:Interaction ;
    rdfs:label "Human–AI policy discussion interaction"@en ;
    hi:hasAgentInvolved hi:PolicyAnalyst ;
    hi:hasAgentInvolved hi:PolicySimulationAgent .

#################################################################
# Student file 7
#################################################################

#################################################################
# domains 
#################################################################

hi:CausalDiscoveryDomain a hi:Domain ;
    rdfs:label "Causal discovery"@en .

hi:BiometricsAndForensicsDomain a hi:Domain ;
    rdfs:label "Biometrics and forensics"@en .

hi:PublicPolicyDomain a hi:Domain ;
    rdfs:label "Public policy"@en .

#################################################################
# Additional methods
#################################################################

hi:LinearRegressionMethod a hi:Method ;
    rdfs:label "Linear regression"@en .

hi:AgentBasedSocialSimulationMethod a hi:Method ;
    rdfs:label "Agent-based social simulation"@en .

hi:DecisionSupportMethod a hi:Method ;
    rdfs:label "Decision support"@en .

#################################################################
# Additional models
#################################################################

hi:CausalDiscoveryModel a hi:Model ;
    rdfs:label "Autonomous causal discovery model"@en ;
    hi:hasMethod hi:LinearRegressionMethod .

hi:FaceMatchingDecisionSupportModel a hi:Model ;
    rdfs:label "Face matching decision support model"@en ;
    hi:hasMethod hi:DecisionSupportMethod .

hi:PolicySimulationModel a hi:Model ;
    rdfs:label "Policy simulation model"@en ;
    hi:hasMethod hi:AgentBasedSocialSimulationMethod .

#################################################################
# Additional metrics
#################################################################

hi:StrategyPerformanceMetric a hi:Metric ;
    rdfs:label "Strategy performance"@en .

hi:DecisionQualityMetric a hi:Metric ;
    rdfs:label "Decision quality"@en .

hi:PolicyScenarioOutcomeMetric a hi:Metric ;
    rdfs:label "Policy scenario outcome"@en .

#################################################################
# Use Case 1 — Causal discovery through repeated interventions
#################################################################

hi:CausalDiscoveryUseCase a hi:UseCase ;
    rdfs:label "Causal discovery through repeated interventions"@en ;
    hi:hasDomain hi:CausalDiscoveryDomain ;
    hi:hasHITeam hi:CausalDiscoveryTeam .

hi:CausalDiscoveryTeam a hi:HITeam ;
    rdfs:label "Causal discovery HI team"@en ;
    hi:hasMember hi:AutonomousCausalLearner ;
    hi:hasMember hi:HumanExperimenter ;
    hi:hasGoal hi:ReconstructHiddenCausalDAGGoal ;
    hi:isInfluencedBy hi:SimulatedWorldContext .

hi:AutonomousCausalLearner a hi:ArtificialAgent ;
    rdfs:label "Autonomous causal learner"@en ;
    hi:operatesInContext hi:SimulatedWorldContext ;
    hi:hasCapability hi:InterveneOnActionableNodes ;
    hi:hasCapability hi:ApplyLinearRegression ;
    hi:performsExecution hi:RepeatedInterventionsExecution .

hi:HumanExperimenter a hi:HumanAgent ;
    rdfs:label "Human experimenter"@en ;
    hi:operatesInContext hi:SimulatedWorldContext ;
    hi:performsExecution hi:RepeatedInterventionsExecution .

hi:SimulatedWorldContext a hi:Context ;
    rdfs:label "Simulated world with hidden causal structure"@en ;
    hi:hasInfluenceOn hi:CausalDiscoveryTeam .

hi:ReconstructHiddenCausalDAGGoal a hi:Goal ;
    rdfs:label "Reconstruct hidden causal DAG"@en ;
    hi:requiresTask hi:PerformInterventionsTask ;
    hi:requiresTask hi:InferCausalLinksTask ;
    hi:requiresTask hi:EvaluateStrategiesTask .

hi:PerformInterventionsTask a hi:Task ;
    rdfs:label "Perform interventions"@en ;
    hi:requiresCapability hi:InterveneOnActionableNodes .

hi:InferCausalLinksTask a hi:Task ;
    rdfs:label "Infer causal links"@en ;
    hi:requiresCapability hi:ApplyLinearRegression .

hi:EvaluateStrategiesTask a hi:Task ;
    rdfs:label "Evaluate intervention strategies"@en ;
    hi:requiresCapability hi:ApplyLinearRegression .

hi:InterveneOnActionableNodes a hi:Capability ;
    rdfs:label "Intervene on actionable nodes"@en ;
    hi:allowsTask hi:PerformInterventionsTask .

hi:ApplyLinearRegression a hi:Capability ;
    rdfs:label "Apply linear regression"@en ;
    hi:allowsTask hi:InferCausalLinksTask ;
    hi:allowsTask hi:EvaluateStrategiesTask .

hi:RepeatedInterventionsExecution a hi:TaskExecution ;
    rdfs:label "Repeated interventions execution"@en ;
    hi:realizesTask hi:PerformInterventionsTask ;
    hi:realizesTask hi:InferCausalLinksTask ;
    hi:realizesTask hi:EvaluateStrategiesTask ;
    hi:towardsGoal hi:ReconstructHiddenCausalDAGGoal ;
    hi:performedBy hi:AutonomousCausalLearner ;
    hi:performedBy hi:HumanExperimenter ;
    hi:usesModel hi:CausalDiscoveryModel ;
    hi:evaluatedBy hi:StrategyComparisonEvaluation ;
    hi:hasInteractionEpisode hi:CausalDiscoveryInteraction .

hi:CausalDiscoveryInteraction a hi:Interaction ;
    rdfs:label "Human–AI causal discovery interaction"@en ;
    hi:hasAgentInvolved hi:AutonomousCausalLearner ;
    hi:hasAgentInvolved hi:HumanExperimenter .

hi:StrategyComparisonEvaluation a hi:Evaluation ;
    rdfs:label "Strategy comparison evaluation"@en ;
    hi:hasExperiment hi:DAG20MaxStrategyExperiment ;
    hi:hasExperiment hi:DAG20MinStrategyExperiment ;
    hi:hasExperiment hi:DAG20RandomStrategyExperiment ;
    hi:hasExperiment hi:DAG20PureRandomStrategyExperiment .

hi:DAG20MaxStrategyExperiment a hi:Experiment ;
    rdfs:label "DAG20 max strategy experiment"@en ;
    hi:hasMetricTested hi:StrategyPerformanceMetric .

hi:DAG20MinStrategyExperiment a hi:Experiment ;
    rdfs:label "DAG20 min strategy experiment"@en ;
    hi:hasMetricTested hi:StrategyPerformanceMetric .

hi:DAG20RandomStrategyExperiment a hi:Experiment ;
    rdfs:label "DAG20 random strategy experiment"@en ;
    hi:hasMetricTested hi:StrategyPerformanceMetric .

hi:DAG20PureRandomStrategyExperiment a hi:Experiment ;
    rdfs:label "DAG20 pure random strategy experiment"@en ;
    hi:hasMetricTested hi:StrategyPerformanceMetric .

#################################################################
# Use Case 2 — Human-AI face matching decision support
#################################################################

hi:FaceMatchingDecisionSupportUseCase a hi:UseCase ;
    rdfs:label "Human–AI face matching decision support"@en ;
    hi:hasDomain hi:BiometricsAndForensicsDomain ;
    hi:hasHITeam hi:FaceMatchingHITeam .

hi:FaceMatchingHITeam a hi:HITeam ;
    rdfs:label "Face matching HI team"@en ;
    hi:hasMember hi:HumanFaceMatcher ;
    hi:hasMember hi:FaceMatchingDecisionSupportSystem ;
    hi:hasGoal hi:ImproveFaceMatchingDecisionsGoal ;
    hi:isInfluencedBy hi:FaceMatchingStudyContext .

hi:FaceMatchingStudyContext a hi:Context ;
    rdfs:label "Face matching study context"@en ;
    hi:hasInfluenceOn hi:FaceMatchingHITeam .

hi:HumanFaceMatcher a hi:HumanAgent ;
    rdfs:label "Human face matcher"@en ;
    hi:operatesInContext hi:FaceMatchingStudyContext ;
    hi:hasCapability hi:HumanFaceMatchingJudgment ;
    hi:performsExecution hi:FaceMatchingTaskExecution .

hi:FaceMatchingDecisionSupportSystem a hi:ArtificialAgent ;
    rdfs:label "Face matching decision support system"@en ;
    hi:operatesInContext hi:FaceMatchingStudyContext ;
    hi:hasCapability hi:ProvideMatchingSuggestions ;
    hi:hasCapability hi:ComputeInteractionMetrics ;
    hi:performsExecution hi:FaceMatchingTaskExecution .

hi:ImproveFaceMatchingDecisionsGoal a hi:Goal ;
    rdfs:label "Improve face matching decisions"@en ;
    hi:requiresTask hi:FaceMatchingNormalSetTask ;
    hi:requiresTask hi:FaceMatchingHardSetTask ;
    hi:requiresTask hi:AssessInfluenceAndConfirmationTask .

hi:FaceMatchingNormalSetTask a hi:Task ;
    rdfs:label "Face matching on normal set"@en ;
    hi:requiresCapability hi:HumanFaceMatchingJudgment ;
    hi:requiresCapability hi:ProvideMatchingSuggestions .

hi:FaceMatchingHardSetTask a hi:Task ;
    rdfs:label "Face matching on hard set"@en ;
    hi:requiresCapability hi:HumanFaceMatchingJudgment ;
    hi:requiresCapability hi:ProvideMatchingSuggestions .

hi:AssessInfluenceAndConfirmationTask a hi:Task ;
    rdfs:label "Assess influence and confirmation"@en ;
    hi:requiresCapability hi:ComputeInteractionMetrics .

hi:HumanFaceMatchingJudgment a hi:Capability ;
    rdfs:label "Human face matching judgment"@en ;
    hi:allowsTask hi:FaceMatchingNormalSetTask ;
    hi:allowsTask hi:FaceMatchingHardSetTask .

hi:ProvideMatchingSuggestions a hi:Capability ;
    rdfs:label "Provide matching suggestions"@en ;
    hi:allowsTask hi:FaceMatchingNormalSetTask ;
    hi:allowsTask hi:FaceMatchingHardSetTask .

hi:ComputeInteractionMetrics a hi:Capability ;
    rdfs:label "Compute interaction metrics"@en ;
    hi:allowsTask hi:AssessInfluenceAndConfirmationTask .

hi:FaceMatchingTaskExecution a hi:TaskExecution ;
    rdfs:label "Face matching task execution"@en ;
    hi:realizesTask hi:FaceMatchingNormalSetTask ;
    hi:realizesTask hi:FaceMatchingHardSetTask ;
    hi:realizesTask hi:AssessInfluenceAndConfirmationTask ;
    hi:towardsGoal hi:ImproveFaceMatchingDecisionsGoal ;
    hi:performedBy hi:HumanFaceMatcher ;
    hi:performedBy hi:FaceMatchingDecisionSupportSystem ;
    hi:usesModel hi:FaceMatchingDecisionSupportModel ;
    hi:evaluatedBy hi:DecisionSupportEvaluation ;
    hi:hasInteractionEpisode hi:HumanDSSInteraction .

hi:HumanDSSInteraction a hi:Interaction ;
    rdfs:label "Human decision-support interaction"@en ;
    hi:hasAgentInvolved hi:HumanFaceMatcher ;
    hi:hasAgentInvolved hi:FaceMatchingDecisionSupportSystem .

hi:DecisionSupportEvaluation a hi:Evaluation ;
    rdfs:label "Decision support evaluation"@en ;
    hi:hasExperiment hi:NoMachineExperiment ;
    hi:hasExperiment hi:Static95Experiment ;
    hi:hasExperiment hi:Static50Experiment ;
    hi:hasExperiment hi:Static5Experiment ;
    hi:hasExperiment hi:IncreasingConfidenceNotifyExperiment ;
    hi:hasExperiment hi:IncreasingConfidenceNoNotifyExperiment ;
    hi:hasExperiment hi:DecreasingConfidenceNotifyExperiment ;
    hi:hasExperiment hi:DecreasingConfidenceNoNotifyExperiment .

hi:NoMachineExperiment a hi:Experiment ;
    rdfs:label "No machine experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:Static95Experiment a hi:Experiment ;
    rdfs:label "Static 95 experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:Static50Experiment a hi:Experiment ;
    rdfs:label "Static 50 experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:Static5Experiment a hi:Experiment ;
    rdfs:label "Static 5 experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:IncreasingConfidenceNotifyExperiment a hi:Experiment ;
    rdfs:label "Increasing confidence notify experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:IncreasingConfidenceNoNotifyExperiment a hi:Experiment ;
    rdfs:label "Increasing confidence no notify experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:DecreasingConfidenceNotifyExperiment a hi:Experiment ;
    rdfs:label "Decreasing confidence notify experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

hi:DecreasingConfidenceNoNotifyExperiment a hi:Experiment ;
    rdfs:label "Decreasing confidence no notify experiment"@en ;
    hi:hasMetricTested hi:DecisionQualityMetric .

#################################################################
# Use Case 3 — Hybrid human policy modeling with simulations
#################################################################

hi:HybridHumanPolicyModelingUseCase a hi:UseCase ;
    rdfs:label "Hybrid human policy modeling with simulations"@en ;
    hi:hasDomain hi:PublicPolicyDomain ;
    hi:hasHITeam hi:HybridHumanPolicyTeam .

hi:HybridHumanPolicyTeam a hi:HITeam ;
    rdfs:label "Hybrid human policy team"@en ;
    hi:hasMember hi:HealthcarePolicyMaker ;
    hi:hasMember hi:ABSSSimulationSystem ;
    hi:hasGoal hi:SupportHealthcarePolicyDecisionsGoal ;
    hi:isInfluencedBy hi:HealthcarePolicyContext .

hi:HealthcarePolicyContext a hi:Context ;
    rdfs:label "Healthcare policy context"@en ;
    hi:hasInfluenceOn hi:HybridHumanPolicyTeam .

hi:HealthcarePolicyMaker a hi:HumanAgent ;
    rdfs:label "Healthcare policy maker"@en ;
    hi:operatesInContext hi:HealthcarePolicyContext ;
    hi:hasCapability hi:QualitativeExpertJudgment ;
    hi:performsExecution hi:ABSSWhatIfAnalysisExecution .

hi:ABSSSimulationSystem a hi:ArtificialAgent ;
    rdfs:label "Agent-based social simulation system"@en ;
    hi:operatesInContext hi:HealthcarePolicyContext ;
    hi:hasCapability hi:SimulateSocialInteractions ;
    hi:hasCapability hi:ProduceSimulationInsights ;
    hi:performsExecution hi:ABSSWhatIfAnalysisExecution .

hi:SupportHealthcarePolicyDecisionsGoal a hi:Goal ;
    rdfs:label "Support healthcare policy decisions"@en ;
    hi:requiresTask hi:RunSocialSimulationsTask ;
    hi:requiresTask hi:InterpretSimulationResultsTask ;
    hi:requiresTask hi:RefinePolicyScenariosTask .

hi:RunSocialSimulationsTask a hi:Task ;
    rdfs:label "Run social simulations"@en ;
    hi:requiresCapability hi:SimulateSocialInteractions .

hi:InterpretSimulationResultsTask a hi:Task ;
    rdfs:label "Interpret simulation results"@en ;
    hi:requiresCapability hi:QualitativeExpertJudgment ;
    hi:requiresCapability hi:ProduceSimulationInsights .

hi:RefinePolicyScenariosTask a hi:Task ;
    rdfs:label "Refine policy scenarios"@en ;
    hi:requiresCapability hi:QualitativeExpertJudgment ;
    hi:requiresCapability hi:ProduceSimulationInsights .

hi:QualitativeExpertJudgment a hi:Capability ;
    rdfs:label "Qualitative expert judgment"@en ;
    hi:allowsTask hi:InterpretSimulationResultsTask ;
    hi:allowsTask hi:RefinePolicyScenariosTask .

hi:SimulateSocialInteractions a hi:Capability ;
    rdfs:label "Simulate social interactions"@en ;
    hi:allowsTask hi:RunSocialSimulationsTask .

hi:ProduceSimulationInsights a hi:Capability ;
    rdfs:label "Produce simulation insights"@en ;
    hi:allowsTask hi:InterpretSimulationResultsTask ;
    hi:allowsTask hi:RefinePolicyScenariosTask .

hi:ABSSWhatIfAnalysisExecution a hi:TaskExecution ;
    rdfs:label "ABSS what-if analysis execution"@en ;
    hi:realizesTask hi:RunSocialSimulationsTask ;
    hi:realizesTask hi:InterpretSimulationResultsTask ;
    hi:realizesTask hi:RefinePolicyScenariosTask ;
    hi:towardsGoal hi:SupportHealthcarePolicyDecisionsGoal ;
    hi:performedBy hi:HealthcarePolicyMaker ;
    hi:performedBy hi:ABSSSimulationSystem ;
    hi:usesModel hi:PolicySimulationModel ;
    hi:evaluatedBy hi:PolicyScenarioEvaluation ;
    hi:hasInteractionEpisode hi:PolicySimulationInteraction .

hi:PolicySimulationInteraction a hi:Interaction ;
    rdfs:label "Human–AI policy simulation interaction"@en ;
    hi:hasAgentInvolved hi:HealthcarePolicyMaker ;
    hi:hasAgentInvolved hi:ABSSSimulationSystem .

hi:PolicyScenarioEvaluation a hi:Evaluation ;
    rdfs:label "Policy scenario evaluation"@en ;
    hi:hasExperiment hi:InSilicoPolicyInterventionExperiment .

hi:InSilicoPolicyInterventionExperiment a hi:Experiment ;
    rdfs:label "In silico policy intervention experiment"@en ;
    hi:hasMetricTested hi:PolicyScenarioOutcomeMetric .
