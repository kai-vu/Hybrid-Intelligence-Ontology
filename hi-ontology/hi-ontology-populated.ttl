    rdfs:label "Multimodal understanding"@en ;
    hi:allowsTask hi:ArchiveVideoSegmentationTask .

hi:ReinforcementLearningSupport a hi:Capability ;
    rdfs:label "Reinforcement learning support"@en ;
    hi:allowsTask hi:ArchiveVideoSegmentationTask .

hi:CulturalStewardship a hi:Capability ;
    rdfs:label "Cultural stewardship"@en ;
    hi:allowsTask hi:ArchivalCollectionTask .

hi:Negotiation a hi:Capability ;
    rdfs:label "Negotiation"@en ;
