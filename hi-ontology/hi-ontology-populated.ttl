### Tasks
hi:BlockSuspiciousTrafficTask a hi:Task ;
    rdfs:label "Block suspicious traffic"@en ;
    hi:requiresCapability hi:PatternRecognitionForThreatDetection,
        hi:CybersecurityContextAssessment .

hi:CrossCheckThreatPredictionTask a hi:Task ;
    rdfs:label "Cross-check threat predictions"@en ;
    hi:requiresCapability hi:SecurityDecisionMaking,
        hi:CybersecurityContextAssessment .

hi:RestoreAccessTask a hi:Task ;
    rdfs:label "Restore legitimate access"@en ;
    hi:requiresCapability hi:SecurityDecisionMaking,
        hi:RapidExplanationGeneration .

hi:ProteinAnalysisTask a hi:Task ;
    rdfs:label "Protein analysis"@en ;
    hi:requiresCapability hi:ProteinStructurePrediction,
        hi:ClinicalJudgment ;
    hi:realizedBy hi:ProteinAnalysisExecution .

hi:ProteinModelGenerationTask a hi:Task ;
    rdfs:label "Protein model generation"@en ;
    hi:requiresCapability hi:ThreeDimensionalModelGeneration .

hi:LiteratureCrossReferencingTask a hi:Task ;
    rdfs:label "Cross-reference scientific literature"@en ;
    hi:requiresCapability hi:LiteratureReview,
        hi:ClinicalJudgment .

hi:ResearchOptimizationTask a hi:Task ;
    rdfs:label "Research-team optimization"@en ;
    hi:requiresCapability hi:ResearchCoordination .

hi:ChildAssessmentTask a hi:Task ;
    rdfs:label "Child assessment"@en ;
    hi:requiresCapability hi:TherapeuticExpertise,
        hi:BehavioristApproach .

hi:EducationalPlanningTask a hi:Task ;
    rdfs:label "Educational planning"@en ;
    hi:requiresCapability hi:PedagogicalSkills,
        hi:TechnologyEnthusiasm .

hi:GuidedRobotInteractionTask a hi:Task ;
    rdfs:label "Guided robot interaction"@en ;
    hi:requiresCapability hi:ReactiveResponse,
        hi:WizardOfOzInteraction,
        hi:TechnologyEnthusiasm .

hi:ArchivalCollectionTask a hi:Task ;
    rdfs:label "Archival footage collection"@en ;
    hi:requiresCapability hi:CulturalStewardship .

hi:ArchiveVideoSegmentationTask a hi:Task ;
    rdfs:label "Video segmentation and tagging"@en ;
    hi:requiresCapability hi:MultimodalUnderstanding,
        hi:ReinforcementLearningSupport .

hi:DataGovernanceNegotiationTask a hi:Task ;
    rdfs:label "Ethical data governance and consent negotiation"@en ;
    hi:requiresCapability hi:Negotiation .

### Goals
hi:ImproveCybersecurityResponseGoal a hi:Goal ;
    rdfs:label "Improve cybersecurity response"@en ;
    hi:requiresTask hi:BlockSuspiciousTrafficTask,
        hi:CrossCheckThreatPredictionTask,
        hi:RestoreAccessTask .

hi:IdentifyNeuroprotectiveProteinsGoal a hi:Goal ;
    rdfs:label "Identify neuroprotective proteins"@en ;
    hi:requiresTask hi:ProteinAnalysisTask,
        hi:LiteratureCrossReferencingTask,
        hi:ResearchOptimizationTask .

hi:ImproveLearningOutcomesGoal a hi:Goal ;
    rdfs:label "Improve learning outcomes"@en ;
    hi:requiresTask hi:ChildAssessmentTask,
        hi:EducationalPlanningTask,
        hi:GuidedRobotInteractionTask .

hi:PreserveAndCurateArchivalKnowledgeGoal a hi:Goal ;
    rdfs:label "Preserve and curate archival knowledge"@en ;
    hi:requiresTask hi:ArchivalCollectionTask,
        hi:ArchiveVideoSegmentationTask,
        hi:DataGovernanceNegotiationTask .

### Teams
hi:CybersecurityResponseTeam a hi:HITeam ;
